# Environment Variables Template
# Copy this file to .env and fill in your actual values

# API Keys
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# JWT Secret Key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=your_jwt_secret_key_here

# Flask Secret Key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your_flask_secret_key_here

# Database URL
DATABASE_URL=sqlite:///calorie_app.db

# Flask Configuration
FLASK_ENV=development
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# CORS Configuration (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:19000,exp://192.168.100.47:19000,http://127.0.0.1:19000

# Rate Limiting (use Redis in production)
REDIS_URL=memory://

# Security (set to true in production)
FORCE_HTTPS=false
SESSION_COOKIE_SECURE=false

# Email Configuration (optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@calorietracker.com
